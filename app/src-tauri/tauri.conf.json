{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarlid",
  "version": "0.6.1",
  "identifier": "com.camer.pandora-desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Jarlid",
        "width": 1100,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCOTcxNjkxNkRGODlGMjkKUldRcG4vaHRrUmFYV3dXRTgvUEZOYkNGMGwwYUZQOXAvOUtsZXJjNFdSaUlVWVdCTUpLczZaVEIK",
      "endpoints": [
        "https://github.com/cinderblock/jarlid/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
