{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "engine",
  "description": "Allow the injected Pandora bridge (remote page) to emit/listen events.",
  "windows": ["engine"],
  "remote": {
    "urls": ["https://*.pandora.com"]
  },
  "permissions": ["core:event:allow-emit", "core:event:allow-listen", "core:event:allow-unlisten"]
}
